# ---- required ----
# Bot token from https://discord.com/developers/applications  →  your app  →  Bot  →  Reset Token
DISCORD_TOKEN=MTUyOTA2MzQ4Njc3OTQyODk0NA.G0CkLA.a3FhgaqXv-vVreR98JiFDhoxaxHfkMJLsJ30OA
# "Application ID" from the same page (General Information)
CLIENT_ID=1529063486779428944

# ---- recommended ----
# Your server ID (right-click the server icon → Copy Server ID, with Developer Mode on).
# If set, slash commands appear instantly. Leave blank to register globally (can take ~1h).
GUILD_ID=1333302103539585024

# ---- optional: fully automatic mode ----
# The channel(s) where Ticket Tool posts transcripts. If set, the bot auto-counts every
# .html transcript posted there — no /sync needed. Right-click a channel → Copy Channel ID.
# For MULTIPLE channels, separate the IDs with commas (spaces optional). For example:
#   TRANSCRIPT_CHANNEL_ID=111111111111111111,222222222222222222,333333333333333333
TRANSCRIPT_CHANNEL_ID=1333302109197566071,1333302109197566068,1333302109197566067,1333302109197566066

# ---- staff auto-detection from Discord roles ----
# Your staff ranks, HIGHEST first, matching your server's role NAMES exactly.
# The bot adds everyone holding one of these roles to the staff list and tags them
# with their highest rank. Edit this list to match your server.
STAFF_ROLES=Server Manager,,Head Administrator,Senior Administrator,Administrator,Moderator,Support

# ---- read everything automatically ----
# true = on every startup, read the ENTIRE history of the transcript channel(s),
# so you never upload transcripts one by one. Already-counted transcripts are
# skipped, so it is safe to leave this on.
SCAN_ON_STARTUP=true

# ---- publish counts to the website (fully automatic) ----
# With these set, the bot commits the ticket counts into your website repo and
# the Ticket Tracker page picks them up on load — no exporting or uploading.
#
# Make a token at https://github.com/settings/personal-access-tokens/new
#   - Repository access: Only select repositories -> your website repo
#   - Permissions: Repository permissions -> Contents -> Read and write
GITHUB_TOKEN=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
GITHUB_REPO=xKatalinax/empiremangment
GITHUB_BRANCH=main
GITHUB_PATH=data/tickets.json
